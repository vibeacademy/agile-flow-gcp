{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(find:*)",
      "Bash(curl:*)",
      "Bash(open http://localhost:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:npmjs.com)",
      "WebSearch",
      "mcp__github__search_issues",
      "mcp__github__get_issue",
      "mcp__github__get_issue_comments",
      "mcp__github__add_issue_comment",
      "mcp__github__list_issues",
      "mcp__github__update_issue",
      "mcp__github__create_issue",
      "mcp__github__create_pull_request",
      "mcp__github__get_pull_request",
      "mcp__github__get_pull_request_files",
      "mcp__github__get_pull_request_status",
      "mcp__github__get_pull_request_comments",
      "mcp__github__get_pull_request_reviews",
      "mcp__github__create_pull_request_review",
      "mcp__github__list_pull_requests",
      "mcp__github__get_file_contents",
      "mcp__github__list_commits",
      "mcp__github__search_code",
      "mcp__memory__create_entities",
      "mcp__memory__create_relations",
      "mcp__memory__search_nodes",
      "mcp__memory__open_nodes",
      "mcp__memory__add_observations",
      "mcp__memory__read_graph",
      "mcp__sequential-thinking__sequentialthinking",
      "SlashCommand(/groom-backlog)",
      "SlashCommand(/work-ticket)",
      "SlashCommand(/review-pr)",
      "SlashCommand(/sprint-status)",
      "SlashCommand(/check-milestone)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.key)",
      "Read(*credentials*)",
      "Read(*secret*)",
      "Write(.env)",
      "Write(.env.*)",
      "mcp__github__merge_pull_request"
    ],
    "ask": []
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "github",
    "memory",
    "sequential-thinking"
  ],
  "_comments": {
    "deny_merge": "IMPORTANT: mcp__github__merge_pull_request is intentionally DENIED to enforce trunk-based development workflow. Only humans can merge PRs. Agents can review (mcp__github__create_pull_request_review) but cannot finalize merges.",
    "deny_secrets": "Secret files (.env, *.key, credentials) are denied to prevent accidental exposure of sensitive data.",
    "bot_accounts": "This template assumes separate bot accounts for worker and reviewer agents. See .claude/README.md for setup instructions."
  }
}
